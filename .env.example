# Groq API Key (get from https://console.groq.com)
GROQ_API_KEY=your_groq_api_key_here

# JWT Secret — must be set, no default (security: never ship with a default secret)
JWT_SECRET=your-super-secret-jwt-key-at-least-256-bits-long-for-hs256

# Database (defaults match compose values — override for local dev)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=smarthire
DB_USERNAME=smarthire
DB_PASSWORD=smarthire

# Kafka (defaults match compose values — override for local dev)
KAFKA_BOOTSTRAP_SERVERS=localhost:9092

# AI Service URL (set by compose to http://ai-service:8000; use localhost for local dev)
AI_SERVICE_URL=http://localhost:8000
